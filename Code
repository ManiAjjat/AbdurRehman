import torch
import torch.nn.functional as F


def sample_smiles(
    model,
    start_token,
    end_token,
    max_length=128,
    temperature=1.0,
    device="cuda"
):

    model.eval()

    current = torch.tensor(
        [[start_token]],
        device=device
    )

    hidden = None

    generated = []

    with torch.no_grad():

        for _ in range(max_length):

            logits, hidden = model(
                current,
                hidden
            )

            logits = (
                logits[:, -1, :]
                / temperature
            )

            probs = F.softmax(
                logits,
                dim=-1
            )

            next_token = torch.multinomial(
                probs,
                1
            )

            token = next_token.item()

            if token == end_token:
                break

            generated.append(
                token
            )

            current = next_token

    return generated
