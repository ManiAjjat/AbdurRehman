import pandas as pd
import json
from rdkit import Chem
from tqdm import tqdm

# ==========================================================
# CONFIGURATION
# ==========================================================

INPUT_FILE = "data/raw/all_smiles.smi"

CLEANED_OUTPUT = "data/processed/cleaned_smiles.csv"

VOCAB_OUTPUT = "data/processed/vocab.json"

MIN_LENGTH = 34
MAX_LENGTH = 128

# ==========================================================
# VALIDATE SMILES
# ==========================================================

def is_valid_smiles(smiles):

    try:
        mol = Chem.MolFromSmiles(smiles)

        if mol is None:
            return False

        return True

    except:
        return False


# ==========================================================
# LOAD DATA
# ==========================================================

print("Loading SMILES...")

with open(INPUT_FILE, "r") as f:

    smiles_list = [line.strip() for line in f]

print(f"Total molecules: {len(smiles_list)}")


# ==========================================================
# CLEAN DATASET
# ==========================================================

cleaned_smiles = []

print("Cleaning molecules...")

for smi in tqdm(smiles_list):

    if not is_valid_smiles(smi):
        continue

    if len(smi) < MIN_LENGTH:
        continue

    if len(smi) > MAX_LENGTH:
        continue

    cleaned_smiles.append(smi)

# ==========================================================
# REMOVE DUPLICATES
# ==========================================================

cleaned_smiles = list(set(cleaned_smiles))

print(f"Remaining molecules: {len(cleaned_smiles)}")

# ==========================================================
# SAVE DATASET
# ==========================================================

df = pd.DataFrame(
    {
        "smiles": cleaned_smiles
    }
)

df.to_csv(
    CLEANED_OUTPUT,
    index=False
)

print(f"Saved cleaned dataset: {CLEANED_OUTPUT}")

# ==========================================================
# BUILD VOCABULARY
# ==========================================================

print("Building vocabulary...")

chars = set()

for smi in cleaned_smiles:

    chars.update(list(smi))

chars = sorted(list(chars))

special_tokens = [
    "<PAD>",
    "<START>",
    "<END>",
    "<UNK>"
]

vocab = special_tokens + chars

char_to_idx = {
    c: i
    for i, c in enumerate(vocab)
}

idx_to_char = {
    i: c
    for i, c in enumerate(vocab)
}

vocab_dict = {
    "vocab_size": len(vocab),
    "char_to_idx": char_to_idx,
    "idx_to_char": idx_to_char
}

with open(VOCAB_OUTPUT, "w") as f:

    json.dump(
        vocab_dict,
        f,
        indent=4
    )

print(f"Vocabulary size: {len(vocab)}")

print(f"Saved vocabulary: {VOCAB_OUTPUT}")

import json
import torch
from torch.utils.data import Dataset


class SmilesTokenizer:

    def __init__(self, vocab_file):

        with open(vocab_file, "r") as f:
            vocab = json.load(f)

        self.char_to_idx = vocab["char_to_idx"]

        self.idx_to_char = {
            int(k): v
            for k, v in vocab["idx_to_char"].items()
        }

        self.vocab_size = vocab["vocab_size"]

        self.pad_token = "<PAD>"
        self.start_token = "<START>"
        self.end_token = "<END>"
        self.unk_token = "<UNK>"

    # ------------------------------------------------
    # Encode SMILES
    # ------------------------------------------------

    def encode(self, smiles):

        tokens = [self.char_to_idx[self.start_token]]

        for ch in smiles:

            if ch in self.char_to_idx:

                tokens.append(
                    self.char_to_idx[ch]
                )

            else:

                tokens.append(
                    self.char_to_idx[self.unk_token]
                )

        tokens.append(
            self.char_to_idx[self.end_token]
        )

        return tokens

    # ------------------------------------------------
    # Decode
    # ------------------------------------------------

    def decode(self, sequence):

        chars = []

        for idx in sequence:

            char = self.idx_to_char.get(idx, "")

            if char in [
                self.start_token,
                self.end_token,
                self.pad_token
            ]:
                continue

            chars.append(char)

        return "".join(chars)

    # ------------------------------------------------
    # One-hot encoding
    # ------------------------------------------------

    def one_hot(self, token_ids):

        return torch.nn.functional.one_hot(
            torch.tensor(token_ids),
            num_classes=self.vocab_size
        ).float()
